{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn hms_project.wsgi --bind 0.0.0.0:$PORT --workers 2 --log-file - --access-logfile - --capture-output",
    "releaseCommand": "python manage.py migrate --noinput && python manage.py collectstatic --noinput",
    "healthcheckPath": "/health/",
    "healthcheckTimeout": 300
  }
}
